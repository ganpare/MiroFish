# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Structured extraction（可选） =====
# 部分供应商对结构化抽取更严格，可以单独切换本体/实体关系抽取模型
# EXTRACT_API_KEY=your_extract_api_key_here
# EXTRACT_BASE_URL=https://api.openai.com/v1
# EXTRACT_MODEL_NAME=gpt-4o-mini

# ===== Report generation（可选） =====
# 报告生成会携带模拟/检索结果原文，若被供应商拦截可单独切换
# REPORT_API_KEY=your_report_api_key_here
# REPORT_BASE_URL=https://api.openai.com/v1
# REPORT_MODEL_NAME=gpt-4o-mini

# ===== 存储后端配置 =====
# zep: 使用 Zep Cloud 图谱
# local: 使用 Neo4j + Qdrant 本地化存储
GRAPH_BACKEND=local
VECTOR_BACKEND=qdrant

# ===== Neo4j（GRAPH_BACKEND=local） =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# ===== Qdrant（VECTOR_BACKEND=qdrant） =====
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION_CHUNKS=mirofish_chunks

# ===== Embedding（默认复用 LLM 配置） =====
# 如果你的供应商不支持 embeddings，可配置支持 embeddings 的提供方，或把 VECTOR_BACKEND=none
# EMBEDDING_API_KEY=your_embedding_api_key_here
# EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL_NAME=text-embedding-3-small

# ===== ZEP（GRAPH_BACKEND=zep 时需要） =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
# ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
